# ========================
# DPU Showcase API 环境配置
# ========================

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (MySQL)
DB_ENGINE=mysql
DB_NAME=showcase
DB_USER=showcase_user
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=3306

# Database URL (优先级高于 DB_* 单独配置，用于生产环境托管数据库)
# 格式: mysql://user:password@host:port/dbname
# DATABASE_URL=mysql://user:password@host:port/dbname

# CORS
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=

# Internal Sync (n8n)
INTERNAL_SYNC_TOKEN=your-sync-token

# SSL CA Certificate
# 如果使用托管数据库（如 DigitalOcean MySQL），需要将 CA 证书文件放在项目根目录
# 文件名为: ca-certificate.crt
# 下载地址通常在数据库提供商的控制台中提供
